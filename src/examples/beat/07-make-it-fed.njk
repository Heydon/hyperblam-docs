{% set previousPost = collections.beat | getPreviousCollectionItem %}
{% set nextPost = collections.beat | getNextCollectionItem %}

{% extends 'layouts/example.njk' %}

{% block audio %}
<chain-blam id="bus">
  <reverb-blam mix="0.2">
    <sample-blam src="{{site.basedir}}/static/sounds/IRs/room-medium.mp3"></sample-blam>
  </reverb-blam>
  <analyser-blam id="analyser"></analyser-blam>
</chain-blam>
<chain-blam id="drums" out="bus">
  <saturator-blam id="crunchy"></saturator-blam>
  <phaser-blam beats="2" bypass></phaser-blam>
  <echo-blam feedback="0.55" cutoff="5000" beats="0.5" mix="0"></echo-blam>
</chain-blam>
<sequencer-blam bpm="90" id="transport" swing>
  <pads-blam id="hat" choke="0.05" out="drums">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/hat/01.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/hat/02.mp3"></sample-blam>
    </bank-blam>
    <blam-blam prop="detune" value="-200~200"></blam-blam>
  </pads-blam>
  <pads-blam id="stab" choke gain="0.7">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/stab.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/stab2.mp3"></sample-blam>
    </bank-blam>
    <chain-blam out="bus">
      <saturator-blam amount="30" lowcut="130"></saturator-blam>
    </chain-blam>
    <lfo-blam prop="detune" gain="45" beats="1">
      <blam-blam prop="beats" value="0.25~1"></blam-blam>
    </lfo-blam>
  </pads-blam>
  <pads-blam id="fdup" gain="1.5" out="bus">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/fdup1.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/fdup2.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/fdup3.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/mayhem/fdup4.mp3"></sample-blam>
    </bank-blam>
    <lfo-blam prop="detune" gain="50" beats="5"></lfo-blam>
  </pads-blam>
  <pads-blam id="kick" out="drums">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/01.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/02.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/03.mp3"></sample-blam>
    </bank-blam>
  </pads-blam>
  <pads-blam id="snare" out="drums">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/01.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/02.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/03.mp3"></sample-blam>
    </bank-blam>
    <blam-blam prop="detune" value="-500~200"></blam-blam>
  </pads-blam>
  <pads-blam id="snareSoft" out="drums">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-soft/01.mp3"></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-soft/02.mp3"></sample-blam>
    </bank-blam>
  </pads-blam>
  <pads-blam id="violins" out="drums" reverse="0.5">
    <bank-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/dissonant/violin/01.mp3" reverse></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/dissonant/violin/02.mp3" reverse></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/dissonant/violin/03.mp3" reverse></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/dissonant/violin/05.mp3" reverse></sample-blam>
      <sample-blam src="{{site.basedir}}/static/sounds/dissonant/violin/08.mp3" reverse></sample-blam>
    </bank-blam>
    <blam-blam prop="detune" value="-300|900"></blam-blam>
  </pads-blam>
  <track-blam id="hatTrack" to="#hat" chance="0.9">
    <bar-blam s="? 0 ? 0 ? ? ? 0"></bar-blam>
    <bar-blam s="? ? 0 0 ? 0 ?">
      <blam-blam to="#crunchy" prop="amount" value="25~100"></blam-blam>
    </bar-blam>
  </track-blam>
  <track-blam id="kickTrack" to="#kick" chance="0.7" override="snareSoftTrack">
    <bar-blam s="1 0 2 0 3"></bar-blam>
    <bar-blam s="1 0 2 0 3 0 ? 0"></bar-blam>
  </track-blam>
  <track-blam to="#snare" override="kickTrack snareSoftTrack">
    <bar-blam s="0 0 0 0 ? 0 0 0">
      <blam-blam to="#crunchy" prop="mode" value="1|1|1|2|3"></blam-blam>
    </bar-blam>
    <bar-blam s="0 0 0 0 ? 0 0 ?"></bar-blam>
  </track-blam>
  <track-blam to="#stab" override="snareTrack hatTrack" suspend>
    <bar-blam s="1 0 0 0 0 0 0 0"></bar-blam>
    <repeat-blam x="2">
      <bar-blam s="0 0 0 0 0 0 0 0"></bar-blam>
    </repeat-blam>
    <bar-blam chance="0.35" s="0 0 2 2 0 2 2 0"></bar-blam>
  </track-blam>
  <track-blam to="#fdup" suspend>
    <repeat-blam x="3">
      <bar-blam s="3 0 4 0 0 0 0 0"></bar-blam>
    </repeat-blam>
    <bar-blam s="0 0 0 0 1 0 2 0"></bar-blam>
  </track-blam>
  <track-blam id="snareSoftTrack" to="#snareSoft" chance="0.5">
    <bar-blam s="0 0 0 0 0 0 ? 0 0 0 ?">
      <blam-blam to="#crunchy" prop="lowcut" value="50~400"></blam-blam>
    </bar-blam>
    <bar-blam s="0 0 0 0 0 0 0 ? ? ?">
      <blam-blam to="#crunchy" prop="highcut" value="4000~11000"></blam-blam>
    </bar-blam>
  </track-blam>
  <track-blam id="violinsTrack" to="#violins" chance="0.25" suspend>
    <bar-blam s="?"></bar-blam>
  </track-blam>
</sequencer-blam>
<tap-blam to="sequencer-blam" prop="playPause">
  <button aria-pressed="false" class="u-round" aria-label="play">{% icon 'playPause' %}</button>
</tap-blam>
{% endblock %}

{% block dialog %}

{% renderTemplate "md" %}

The beat from the previous example is a good basis for something even more _messed_ up. Some dissonant violin samples, sporadically reversed and pumped through the same distortion modes, sound like guitar feedback in places.

{% endrenderTemplate %}

{% endblock %}

{% block controls %}
<dial-blam to="sequencer-blam" prop="bpm">
  <label>
    bpm
    <input type="range" min="30" max="180" step="1">
    <display-blam element="sequencer-blam" prop="bpm" aria-hidden="true"></display-blam>
  </label>
</dial-blam>
<dial-blam to="echo-blam" prop="mix">
  <label>
    echo
    <input type="range" min="0" max="1" step="any">
  </label>
</dial-blam>
<switch-blam to="phaser-blam" prop="bypass" reverse>
  <label>
    phaser
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to="[to='#stab'], [to='#fdup']" prop="suspend" reverse>
  <label>
    f**cked
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to="#violinsTrack" prop="suspend" reverse>
  <label>
    strings
    <input type="checkbox">
  </label>
</switch-blam>
<kbd-blam to="#kick" key="1" prop="play"></kbd-blam>
<kbd-blam to="#snare" key="2" prop="play"></kbd-blam>
<kbd-blam to="#snareSoft" key="3" prop="play"></kbd-blam>
<kbd-blam to="#hat" key="4" prop="play"></kbd-blam>
<watch-blam aria-hidden="true" from="audio-blam *:not(bands-blam)" to="log" additive bypass>
  <li><strong>[[id]]</strong> [[name]] → [[newValue]]</li>
</watch-blam>
<blam-blam from="sequencer-blam" to="watch-blam" prop="bypass" event="blamplay" once></blam-blam>
{% endblock %}