          <feDisplacementMap in="SourceGraphic" scale="90"/>
        </filter>
        <filter id="distort-2">
          <feTurbulence baseFrequency="0.009 0.3" numOctaves="2"/>
          <feDisplacementMap in="SourceGraphic" scale="110"/>
        </filter>
        <filter id="distort-3">
          <feTurbulence baseFrequency="0.003 0.1" numOctaves="16"/>
          <feDisplacementMap in="SourceGraphic" scale="200"/>
        </filter>
        <filter id="distort-4">
          <feTurbulence baseFrequency="0.007 0.2" numOctaves="1"/>
          <feDisplacementMap in="SourceGraphic" scale="100"/>
        </filter>
        <filter id="distort-5">
          <feTurbulence baseFrequency="0.001 0.1" numOctaves="1"/>
          <feDisplacementMap in="SourceGraphic" scale="70"/>
        </filter>
      </defs>
    </svg>
    <audio-blam>
      <section id="intro">
        <h1>MAKING HTML<br> MAKE MUSIC</h1>
        <p class="u-tilt">with <a href="#">Heydon</a></p>
      </section>
      <section id="cowbell">
        <dial-blam>
          <label>
            cowbell 
            <input type="range">
          </label>
        </dial-blam>
      </section>
      <section id="other">
        <h1>3</h1></p>
      </section>      
    </audio-blam>

    <script>
      const fire = (name, data, target = window, bubbles = false) => {
        let event = new CustomEvent(name, {
          detail: data,
          bubbles: bubbles
        });

        target.dispatchEvent(event);
      }

      const slides = [... document.querySelectorAll('section')];

      slides.forEach((s, i) => {
        s.hidden = true;
        s.id = `slide-${i + 1}`
      });
      slides[0].hidden = false;

      document.addEventListener('keydown', e => {
        let thisSlide = document.querySelector('section:not([hidden])');
        if (!event.key.includes('Arrow')) {
          return;
        }
        let back = ['Up', 'Left'].some(key => e.key.includes(key));
        let newDir = back ? 'previous' : 'next';
        let newSlide = thisSlide[`${newDir}ElementSibling`];
        if (!newSlide) {
          return;
        }
        if (!window.waiting) {
          thisSlide.classList.add('wait');
          window.waiting = true;
          window.lastKey = e.key;
          fire('slidewaiting', {}, this);
          return;
        }
        if (window.lastKey !== e.key) {
          return;  
        }
        slides.forEach(slide => slide.hidden = true);
        thisSlide.classList.remove('wait');
        window.waiting = newSlide.hidden = false;
        fire('slidechange', {}, this);
      });
    </script>
    <script type="module" src="{{site.basedir}}/{{site.hyperblampath}}"></script>
  </body>
</html>