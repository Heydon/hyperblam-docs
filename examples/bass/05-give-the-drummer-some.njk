{% set previousPost = collections.bass | getPreviousCollectionItem %}
{% set nextPost = collections.bass | getNextCollectionItem %}

{% extends 'layouts/example.njk' %}

{% block visual %}
  <div class="l-frame__framed">
    <rings-blam 
      id="example" 
      fps="6"
      ratio="1 / 1"
      analyser="#analyser" 
      transport="#transport"
      style="inline-size: 75vw; max-block-size: 100%"
      count="{{ visualiser.count }}",
      first="{{ visualiser.first }}",
      last="{{ visualiser.last }}"
    >
    </rings-blam>
  </div>
{% endblock %}

{% block audio %}
<chain-blam id="bus">
  <analyser-blam id="analyser" smoothing="0.5"></analyser-blam>
</chain-blam>
<notes-blam choke="0.02" notes="A1 A1 A1 C2 D2 D#2 E2 G1 A2 C3">
  <bank-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/bass/01.mp3" root="A1"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/bass/02.mp3" root="C#2"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/bass/03.mp3" root="E2"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/bass/04.mp3" root="A2"></sample-blam>
  </bank-blam>
  <blam-blam prop="length" value="0.25|0.5|0.5|0.125|1"></blam-blam>
  <chain-blam out="bus">
    <filter-blam freq="8000" q="10">
      <envelope-blam prop="freq" curve="200 0, 11000 0.25"></envelope-blam>
    </filter-blam>
  </chain-blam>
  <relay-blam mode="one" chance="0.333">
    <envelope-blam to="notes-blam" prop="detune" curve="-300 0, 0 0.125" beats off></envelope-blam>
    <envelope-blam to="notes-blam" prop="detune" curve="0 0, 50 0.25, 0 0.5" beats off></envelope-blam>
  </relay-blam>
</notes-blam>
<pads-blam id="kick" out="bus" detune="300">
  <bank-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/01.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/02.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/kick/03.mp3"></sample-blam>
  </bank-blam>
</pads-blam>
<pads-blam id="hat" choke out="bus" detune="300">
  <bank-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/hat/01.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/hat/02.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/hat/03.mp3"></sample-blam>
  </bank-blam>
</pads-blam>
<pads-blam id="snare" out="bus" detune="200">
  <bank-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/01.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/02.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-hard/03.mp3"></sample-blam>
  </bank-blam>
</pads-blam>
<pads-blam id="snareSoft" out="bus">
  <bank-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-soft/01.mp3"></sample-blam>
    <sample-blam src="{{site.basedir}}/static/sounds/kit-garage/snare-soft/02.mp3"></sample-blam>
  </bank-blam>
</pads-blam>
<sequencer-blam bpm="90" id="transport">
  <track-blam id="bassTrack" to="notes-blam" chance="0.75">
    <bar-blam s="A1 0 0 ? 0 ? ? 0"></bar-blam>
    <bar-blam s="C2 0 ? 0 0 ? ? 0"></bar-blam>
  </track-blam>
  <track-blam id="kickTrack" to="#kick" chance="0.5" override="snareSoftTrack">
    <bar-blam s="1 0 0 3 0 2 1 0"></bar-blam>
    <bar-blam s="1 0 1 3 0 2 1 0"></bar-blam>
  </track-blam>
  <track-blam id="hatTrack" to="#hat" chance="1">
    <bar-blam s="1 0 2 0 1 ? ? 0"></bar-blam>
    <bar-blam s="1 2 0 0 1 0 ?"></bar-blam>
  </track-blam>
  <track-blam id="snareTrack" to="#snare" override="kickTrack snareSoftTrack" chance="0.9">
    <bar-blam s="0 0 0 0 ? 0 0 0"></bar-blam>
    <bar-blam s="0 0 ? 0 0 0 0 0"></bar-blam>
    <blam-blam from="#snareTrack" to="#hatTrack" prop="solo" chance="0.1" revert></blam-blam>
  </track-blam>
  <track-blam id="snareSoftTrack" to="#snareSoft" chance="0.6">
    <bar-blam s="0 0 0 0 0 0 ? 0 0 0 ?"></bar-blam>
    <bar-blam s="0 0 0 0 0 0 0 ? ? ?"></bar-blam>
  </track-blam>
</sequencer-blam>
<tap-blam id="transport" to="sequencer-blam" prop="playPause">
  <button aria-pressed="false" class="u-round" aria-label="play">{% icon 'playPause' %}</button>
</tap-blam>
{% endblock %}

{% block dialog %}

{% renderTemplate "md" %}

Let’s bring in the drum sounds from the [**Beat** examples](/examples/04-getting-ghosted/) and get a full rhythm section going. There’s so much variation happening, it holds some interest without any other instruments in play, don’t you think? Enough to soundtrack 3 or 4 hours of porn, in any case.

Notable in this example is the use of a `<blam-blam>` element to toggle the hi-hat track’s `solo` prop. Every time the snare track plays a snare, there’s a slim (`0.1` or 10%) chance `solo` will be switched on and all other tracks silenced.

```html
<blam-blam from="#snareTrack" to="#hatTrack" prop="solo" chance="0.1" revert></blam-blam>
```

Because `revert` is also set, there’s a 100% chance `solo` will “snap back” to `false` the next time a snare comes around. You can create all sorts of compositional fluctuations this way.
  
Since a `<switch-blam>` is provided for the same purpose of soloing the hi-hat, its input’s checked state must stay in sync.

```html 
<switch-blam to="#hatTrack" prop="solo">
  <label>
    hat solo
    <input type="checkbox">
  </label>
</switch-blam>
```

Fortunately, **HYPERBLAM** sees to this automatically. You’ll see the switch toggle whenever `<blam-blam>` does its thing. You can either sit back and watch these kinds of automated changes take place, or you can intervene and change them when it feels right. Some stimulating interfaces can be made this way.

{% endrenderTemplate %}

{% endblock %}

{% block controls %}
<switch-blam to="sequencer-blam" prop="swing" value="0.2">
  <label>
    swing
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to="#bassTrack" prop="solo">
  <label>
    bass solo
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to="#hatTrack" prop="solo">
  <label>
    hat solo
    <input type="checkbox">
  </label>
</switch-blam>
{% endblock %}