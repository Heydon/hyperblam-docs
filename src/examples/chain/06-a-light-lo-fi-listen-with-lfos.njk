{% endblock %}

{% block controls %}
<switch-blam to="#pianoTrack" prop="solo">
  <label>
    solo keys
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to=".drum" prop="solo">
  <label>
    just drums
    <input type="checkbox">
  </label>
</switch-blam>
<switch-blam to="#killswitch" prop="bypass" reverse>
  <label>
    chop keys
    <input type="checkbox">
  </label>
</switch-blam>
<dial-blam to="#highpass" prop="freq">
  <label>
    cutoff
    <input type="range" min="50" max="2000" step="10">
  </label>
</dial-blam>
<kbd-blam to="#tom" prop="play" key="1"></kbd-blam>
<kbd-blam to="#snare" prop="play" key="2"></kbd-blam>
<kbd-blam to="#pluck" prop="play" key="3"></kbd-blam>
{% endblock %}