<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    {% block title %}
    <title>{{ title }} : {{ site.title }}</title>
    {% endblock %}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="{{site.basedir}}/static/css/fonts.css" />
    <link rel="stylesheet" href="{{site.basedir}}/static/css/styles.css" />
     <link rel="preload" href="{{site.basedir}}/static/css/fonts/HeydonCaps.woff2" as="font" type="font/woff2" crossorigin>
  </head>
  <body>
    {% block bodyStart %}
    {% endblock %}
    {% block nav %}
    <header class="l-box">
      <a href="#main" class="l-skip">skip to content</a>
    </header>
    {% endblock %}
    {% block main %}
    <main class="l-column l-flow" tabindex="-1">
        <h1>{{ title }}</h1>
        {{ content | safe }}
    </main>
    {% endblock %}
    {% block footer %}
    <footer class="u-font-smaller">
      <p>Created by <a href="https://front-end.social/@heydon">Heydon Pickering</a></p>
      <p>Version: <strong>{{ package.version }}</strong></p>
    </footer>
    {% endblock %}
    {% block scripts %}
    {% endblock %}
  </body>
</html>